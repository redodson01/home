[commit]
	gpgSign = true
[core]
	pager = delta
[delta]
	navigate = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	process = git-lfs filter-process
	required = true
	smudge = git-lfs smudge -- %f
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only
[merge]
	conflictStyle = zdiff3
[tag]
	gpgSign = true
[user]
	email = richardedodson01@icloud.com
	name = Richard E. Dodson
