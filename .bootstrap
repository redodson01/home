#!/usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

if [[ -n "${DEBUG:-}" ]]; then
  set -o xtrace
fi

if [[ ! -d "${HOME}/.ssh" ]]; then
  git clone --branch="$(scutil --get LocalHostName)" https://github.com/redodson01/.ssh.git "${HOME}/.ssh"
  git -C "${HOME}/.ssh" remote set-url origin git@github.com:redodson01/.ssh.git
  chmod 400 "${HOME}/.ssh/id_ed25519"
fi

if [[ ! -d "${HOME}/.local/share/home" ]]; then
  git init --bare --initial-branch=main "${HOME}/.local/share/home"
  git --git-dir="${HOME}/.local/share/home" config status.showUntrackedFiles no
  git --git-dir="${HOME}/.local/share/home" remote add -f origin git@github.com:redodson01/home.git
  git --git-dir="${HOME}/.local/share/home" --work-tree="${HOME}" checkout --force main
  git --git-dir="${HOME}/.local/share/home" --work-tree="${HOME}" submodule update --init --remote
  git --git-dir="${HOME}/.local/share/home" --work-tree="${HOME}" submodule foreach git checkout --force main
  chmod 700 "${HOME}/.gnupg"
fi

if command -v /opt/homebrew/bin/brew > /dev/null; then
  eval "$(/opt/homebrew/bin/brew shellenv bash)"
  brew update
else
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv bash)"
fi

brew bundle install --global
brew bundle cleanup --global --force

if [[ "$(dscl . -read "${HOME}" UserShell)" != 'UserShell: /opt/homebrew/bin/bash' ]]; then
  sudo chsh -s "${HOMEBREW_PREFIX}/bin/bash" "${USER}"
fi

if [[ -f "${HOME}/.vim/autoload/plug.vim" ]]; then
  vim -c PlugUpgrade -c PlugUpdate -c 'PlugClean!' -c quitall
else
  curl -fLo ~/.vim/autoload/plug.vim --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
  vim -c PlugUpdate -c 'PlugClean!' -c quitall
fi

curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash

if command -v rustup > /dev/null; then
  rustup update
else
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- --no-modify-path -y
fi

if command -v claude > /dev/null; then
  claude update
else
  curl -fsSL https://claude.ai/install.sh | bash
fi

cmd-guard --setup

if command -v gh > /dev/null && ! gh auth status > /dev/null; then
  gh auth login
fi
