#!/usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

if [[ -n "${DEBUG:-}" ]]; then
  set -o xtrace
fi

cd

git --git-dir="${HOME}/.local/share/home" --work-tree="${HOME}" ls-files -z |
  xargs --null file --mime-type --no-pad |
  rg --pcre2 --only-matching '^.*(?=: text/x-shellscript$)' |
  xargs --verbose shfmt --indent 2 "${@:---diff}"
